{
  "name": "gdesumipare-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --ext js,mjs,cjs --watch src src/server.js",
    "start": "node src/server.js",
    "migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "seed": "knex --knexfile knexfile.cjs seed:run",
    "reminders": "node src/jobs/sendReminders.js",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "knex": "^3.1.0",
    "nodemon": "^3.1.0"
  }
}
